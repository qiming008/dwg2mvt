# 工作目录（上传与转换产物）
APP_WORK_DIR=./data
# LibreDWG：已加入 PATH 填 dwg2dxf，否则填完整路径如 D:/Tools/libredwg/dwg2dxf.exe
APP_DWG2DXF_CMD=dwg2dxf
# GDAL：同上，或填完整路径如 C:/Program Files/OSGeo4W64/bin/ogr2ogr.exe
APP_OGR2OGR_CMD=ogr2ogr
# 输出坐标系（默认 WGS84 经纬度）
APP_TARGET_SRS=EPSG:4326
# 高斯 - 克吕格投影配置（用于 DWG 坐标转经纬度）
# 投影带号（1-60），根据经度确定：带号 = int(经度/6) + 31 (6 度带) 或 int(经度/3) + 1 (3 度带)
# 如果不设置，默认使用 39 带（适用于中国东部地区，如山东、江苏）
APP_GAUSS_KRUGER_ZONE=39
# 是否启用高斯 - 克吕格到 WGS84 的转换（默认启用）
APP_ENABLE_GAUSS_KRUGER_TRANSFORM=true
# GeoServer（可选，不配置则仅做 DWG→GPKG 转换）
APP_GEOSERVER_URL=http://localhost:8080/geoserver
APP_GEOSERVER_USER=admin
APP_GEOSERVER_PASSWORD=geoserver
APP_GEOSERVER_WORKSPACE=dwg
# 前端访问 GeoServer 的地址（跨域时填公网或代理地址）
# APP_GEOSERVER_PUBLIC_URL=
